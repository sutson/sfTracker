<Window
	x:Class="sfTracker.ConfirmDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
	Width="300"
	Height="130"
    Title="Confirmation"
>
    <StackPanel Margin="0" Background="#dadaf0">
        <TextBlock Text="Any unsaved changes will be lost. Continue?" Margin="20 20 0 20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Yes" Background="#babae0" Width="100" Margin="0 0 10 0" Click="Yes_Click"/>
            <Button Content="No" Background="#babae0" Width="100" Click="No_Click"/>
		</StackPanel>
    </StackPanel>
</Window>