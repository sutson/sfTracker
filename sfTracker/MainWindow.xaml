<Window x:Class="sfTracker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:sfTracker.GUI"
    Title="sfTracker"
    WindowState="Maximized"
    Background="#1f1e33">

    <!-- https://github.com/angelsix/fasetto-word/blob/develop/Source/Fasetto.Word/Styles/Scroll.xaml -->
    <Window.Resources>
        <Style x:Key="VerticalScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle"
                                SnapsToDevicePixels="True"
                                Background="FloralWhite"
                                CornerRadius="1"
                                Height="53"
                                Width="NaN"
                                Margin="0,0,-5,-53"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizontalScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle"
                        SnapsToDevicePixels="True"
                        Background="FloralWhite"
                        CornerRadius="1"
                        Height="NaN"
                        Width="200" Margin="-200 -5 0 0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Margin" Value="-14 0 0 0" />
            <Setter Property="MinWidth" Value="{Binding Width, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">

                            <Border Padding="0 5" Background="Transparent">
                                <Track x:Name="PART_Track"
                                   IsDirectionReversed="true"
                                   IsEnabled="{TemplateBinding IsMouseOver}"
                                   Width="10"
                                   HorizontalAlignment="Center"
                                >
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Opacity="0" Command="{x:Static ScrollBar.PageUpCommand}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Opacity="0" Command="{x:Static ScrollBar.PageDownCommand}" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource VerticalScrollBarThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="Height" Value="14"/>
                    <Setter Property="MinHeight" Value="{Binding Height, RelativeSource={RelativeSource Self}}"/>
                    <Setter Property="Margin" Value="0 -14 0 0" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                    <Track x:Name="PART_Track"
                                    IsEnabled="{TemplateBinding IsMouseOver}"
                                    Height="5"
                                       >
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Opacity="0" Command="{x:Static ScrollBar.PageLeftCommand}"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Opacity="0" Command="{x:Static ScrollBar.PageRightCommand}"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource HorizontalScrollBarThumb}" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VerticalLineTop" TargetType="Line">
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Y1" Value="11"/>
            <Setter Property="Y2" Value="20"/>
        </Style>

        <Style x:Key="VerticalLineMiddle" TargetType="Line">
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Y1" Value="125"/>
            <Setter Property="Y2" Value="1000"/>
        </Style>

        <Style x:Key="VerticalLineBottom" TargetType="Line">
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Y1" Value="0"/>
            <Setter Property="Y2" Value="1000"/>
        </Style>

        <ControlTemplate x:Key="HorizontalSliderTemplate" TargetType="Slider">
            <Track x:Name="PART_Track" IsDirectionReversed="False">

                <Track.DecreaseRepeatButton>
                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                </Track.DecreaseRepeatButton>

                <Track.Thumb>
                    <Thumb Width="100" Height="10" Margin="10 0 20 0">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border x:Name="ThumbBorder" Background="FloralWhite" CornerRadius="5" SnapsToDevicePixels="True">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ThumbScale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                        To="1.2"
                                                        Duration="0:0:0.1"
                                                        FillBehavior="HoldEnd"
                                                    />
                                                    <ColorAnimation
                                                        Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="Gray"
                                                        Duration="0:0:0.1"
                                                    />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                        To="1"
                                                        Duration="0:0:0.1"
                                                    />
                                                    <ColorAnimation
                                                        Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="FloralWhite"
                                                        Duration="0:0:0.05"
                                                    />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Track.Thumb>

                <Track.IncreaseRepeatButton>
                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                </Track.IncreaseRepeatButton>

            </Track>
        </ControlTemplate>

        <ControlTemplate x:Key="VerticalSliderTemplate" TargetType="Slider">
                <Track x:Name="PART_Track" IsDirectionReversed="False">

                    <Track.DecreaseRepeatButton>
                        <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                    </Track.DecreaseRepeatButton>

                    <Track.Thumb>
                        <Thumb Width="10" Height="100">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbBorder" Background="FloralWhite" CornerRadius="5" SnapsToDevicePixels="True">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="ThumbScale" ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                            To="1.2"
                                                            Duration="0:0:0.1"
                                                            FillBehavior="HoldEnd"
                                                        />
                                                        <ColorAnimation
                                                            Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="Gray"
                                                            Duration="0:0:0.1"
                                                        />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                            To="1"
                                                            Duration="0:0:0.1"
                                                        />
                                                        <ColorAnimation
                                                            Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="FloralWhite"
                                                            Duration="0:0:0.05"
                                                        />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>

                    <Track.IncreaseRepeatButton>
                        <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                    </Track.IncreaseRepeatButton>

                </Track>
            </ControlTemplate>
    </Window.Resources>
    
    <Grid Panel.ZIndex="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="250" />
            <!-- section for controls + instruments -->
            <RowDefinition Height="20" />
            <!-- section for above tracker -->
            <RowDefinition Height="*" />
            <!-- section for tracker + scrollbar -->
            <RowDefinition Height="30" />
            <!-- section for tracker + scrollbar -->
        </Grid.RowDefinitions>

        <!-- container for controls and preset selection -->
        <Grid Background="Transparent"  PreviewMouseWheel="Grid_PreviewMouseWheel" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Background="Transparent" Grid.Column="0" HorizontalAlignment="Stretch"></TextBlock>

            <!-- MARGIN: LEFT, TOP, RIGHT, BOTTOM -->
            <Border Grid.Column="2" BorderThickness="1" BorderBrush="White" Margin="0 5 5 10">
                <!-- container for preset selection -->
                <Grid Background="Transparent" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button VerticalAlignment="Center" Margin="5 5 0 5" Padding="5" Click="Button_OpenSF2" Grid.Column="0">Import .sf2 File</Button>
                        <TextBlock x:Name="SelectedSoundFont" Text="" VerticalAlignment="Center" Grid.Column="2" Foreground="FloralWhite" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <ListBox Grid.Row="0"
                             ItemsSource="{Binding Presets}"
                             SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                             PreviewKeyDown="ListBox_PreviewKeyDown"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        >
                            <ListBox.Resources>
                                <Style x:Key="HorizontalThumbStyle" TargetType="Thumb">
                                    <Setter Property="Height" Value="8"/>
                                    <Setter Property="Background" Value="FloralWhite"/>
                                    <Setter Property="Margin" Value="5 0 5 0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <Style TargetType="ScrollBar">
                                    <Style.Triggers>
                                        <Trigger Property="Orientation" Value="Horizontal">
                                            <Setter Property="Height" Value="8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid Background="Transparent">
                                                            <Track x:Name="PART_Track">

                                                                <Track.DecreaseRepeatButton>
                                                                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                                                                </Track.DecreaseRepeatButton>

                                                                <Track.Thumb>
                                                                    <Thumb Style="{StaticResource HorizontalThumbStyle}"/>
                                                                </Track.Thumb>

                                                                <Track.IncreaseRepeatButton>
                                                                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                                                                </Track.IncreaseRepeatButton>

                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>

                                    </Style.Triggers>
                                </Style>

                            </ListBox.Resources>

                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="ScrollViewer.HorizontalAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}"  />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- container to separate controls from tracker -->
        <Grid Background="Transparent"  PreviewMouseWheel="Grid_PreviewMouseWheel" Grid.Row="1">
            <Border BorderThickness="1" Height="1" BorderBrush="White" Grid.Row="1"/>

            <Line Style="{StaticResource VerticalLineTop}" X1="10" X2="10"/>
            <Line Style="{StaticResource VerticalLineTop}" X1="50" X2="50"/>
            <Line Style="{StaticResource VerticalLineTop}" X1="170" X2="170"/>
            <Line Style="{StaticResource VerticalLineTop}" X1="290" X2="290"/>
            <Line Style="{StaticResource VerticalLineTop}" X1="410" X2="410"/>
            <Line Style="{StaticResource VerticalLineTop}" X1="530" X2="530"/>
        </Grid>

        <Line Style="{StaticResource VerticalLineMiddle}" X1="10" X2="10"/>
        <Line Style="{StaticResource VerticalLineMiddle}" X1="50" X2="50"/>
        <Line Style="{StaticResource VerticalLineMiddle}" X1="170" X2="170"/>
        <Line Style="{StaticResource VerticalLineMiddle}" X1="290" X2="290"/>
        <Line Style="{StaticResource VerticalLineMiddle}" X1="410" X2="410"/>
        <Line Style="{StaticResource VerticalLineMiddle}" X1="530" X2="530"/>

        <!-- container for tracker grid and vertical slider -->
        <Grid Background="Transparent"  PreviewMouseWheel="Grid_PreviewMouseWheel" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <!-- tracker part -->
                <ColumnDefinition Width="Auto" />
                <!-- scroll bar part -->
            </Grid.ColumnDefinitions>

            <Line Style="{StaticResource VerticalLineBottom}" X1="10" X2="10"/>
            <Line Style="{StaticResource VerticalLineBottom}" X1="50" X2="50"/>
            <Line Style="{StaticResource VerticalLineBottom}" X1="170" X2="170"/>
            <Line Style="{StaticResource VerticalLineBottom}" X1="290" X2="290"/>
            <Line Style="{StaticResource VerticalLineBottom}" X1="410" X2="410"/>
            <Line Style="{StaticResource VerticalLineBottom}" X1="530" X2="530"/>

            <!-- TrackerGrid aligned left -->
            <local:TrackerGrid x:Name="Tracker"
                               Grid.Column="0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Stretch"
                               Margin="50 200 0 200"
                               />

            <!-- Slider aligned right -->
            <Slider
                x:Name="VerticalScrollBar"
                Orientation="Vertical"
                Grid.Column="1"
                Margin="0 0 10 10"
                Minimum="0"
                SmallChange="1"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="VerticalScrollBar_ValueChanged"
                Template="{StaticResource VerticalSliderTemplate}"
                >
                <Slider.LayoutTransform>
                    <ScaleTransform ScaleY="-1"/>
                </Slider.LayoutTransform>
            </Slider>
        </Grid>

        <!-- bottom section for horizontal scrollbar -->
        <Grid Background="#1f1e33" Grid.Row="3" Panel.ZIndex="1">
            <Border Background="Transparent" Margin="10 0 0 0" BorderThickness="0 1 0 0" BorderBrush="White" />
            <Slider
                x:Name="HorizontalScrollBar"
                Minimum="0"
                Maximum="100"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                Height="20"
                ValueChanged="HorizontalScrollBar_ValueChanged"
                Template="{StaticResource HorizontalSliderTemplate}"
            />
        </Grid>
    </Grid>
</Window>