<Window x:Class="sfTracker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:sfTracker.GUI"
    Title="{Binding WindowTitle}"
    WindowState="Maximized"
    Background="#1f1e33">
    <!-- COLOURS: dark bg = #141424
                  light header = #353554
    -->
    <!-- https://github.com/angelsix/fasetto-word/blob/develop/Source/Fasetto.Word/Styles/Scroll.xaml -->
    <Window.Resources>
        <!-- templates for vertical line rendering (redundant) -->
        <Style x:Key="VerticalLineTop" TargetType="Line">
            <Setter Property="Stroke" Value="FloralWhite"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Y1" Value="11"/>
            <Setter Property="Y2" Value="20"/>
        </Style>
        <Style x:Key="VerticalLineMiddle" TargetType="Line">
            <Setter Property="Stroke" Value="FloralWhite"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Y1" Value="125"/>
            <Setter Property="Y2" Value="1000"/>
        </Style>
        <Style x:Key="VerticalLineBottom" TargetType="Line">
            <Setter Property="Stroke" Value="FloralWhite"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Y1" Value="0"/>
            <Setter Property="Y2" Value="1000"/>
        </Style>

        <!-- template for horizontal slider (scroll) -->
        <ControlTemplate x:Key="HorizontalSliderTemplate" TargetType="Slider">
            <Track x:Name="PART_Track" IsDirectionReversed="False">

                <Track.DecreaseRepeatButton>
                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                </Track.DecreaseRepeatButton>

                <Track.Thumb>
                    <Thumb Width="100" Height="10" Margin="10 0 20 0">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border x:Name="ThumbBorder" Background="FloralWhite" CornerRadius="5" SnapsToDevicePixels="True">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ThumbScale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                        To="1.2"
                                                        Duration="0:0:0.1"
                                                        FillBehavior="HoldEnd"
                                                    />
                                                    <ColorAnimation
                                                        Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="Gray"
                                                        Duration="0:0:0.1"
                                                    />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                        To="1"
                                                        Duration="0:0:0.1"
                                                    />
                                                    <ColorAnimation
                                                        Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="FloralWhite"
                                                        Duration="0:0:0.05"
                                                    />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Track.Thumb>

                <Track.IncreaseRepeatButton>
                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                </Track.IncreaseRepeatButton>

            </Track>
        </ControlTemplate>

        <!-- template for vertical slider (scroll) -->
        <ControlTemplate x:Key="VerticalSliderTemplate" TargetType="Slider">
                <Track x:Name="PART_Track" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Width="10" Height="100">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbBorder" Background="FloralWhite" CornerRadius="5" SnapsToDevicePixels="True">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="ThumbScale" ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                            To="1.2"
                                                            Duration="0:0:0.1"
                                                            FillBehavior="HoldEnd"
                                                        />
                                                        <ColorAnimation
                                                            Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="Gray"
                                                            Duration="0:0:0.1"
                                                        />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                            To="1"
                                                            Duration="0:0:0.1"
                                                        />
                                                        <ColorAnimation
                                                            Storyboard.TargetName="ThumbBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="FloralWhite"
                                                            Duration="0:0:0.05"
                                                        />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </ControlTemplate>

        <!-- template for vertical slider (frame) -->
        <ControlTemplate x:Key="FrameVerticalSliderTemplate" TargetType="Slider">
            <Track x:Name="PART_Track" IsDirectionReversed="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Width="10" Height="50">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border x:Name="ThumbBorder" Background="FloralWhite" CornerRadius="5" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </ControlTemplate>
    </Window.Resources>

    <Grid Panel.ZIndex="0" MouseDown="Window_MouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="250" />
            <!-- section for controls + instruments -->
            <RowDefinition Height="1" />
            <!-- section for above tracker -->
            <RowDefinition Height="*" />
            <!-- section for tracker + scrollbar -->
            <RowDefinition Height="30" />
            <!-- section for tracker + scrollbar -->
        </Grid.RowDefinitions>

        <!-- container for controls and preset selection -->
        <Grid Grid.Row="0" Margin="0 5 0 5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500" />
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="Transparent" BorderThickness="1" BorderBrush="FloralWhite" Margin="10 5 0 10">
                <!-- container for pattern selection / adding -->
                <Grid Background="#141424" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="Transparent"  BorderThickness="0 0 0 1" BorderBrush="FloralWhite">
                        <Grid Grid.Row="0" Background="#353554">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="PatternSection"
                                Text="Patterns"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Margin="10 0 0 2"
                                TextAlignment="Left"
                                Grid.Column="0"
                                Foreground="FloralWhite"
                            />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Background="Transparent" PreviewMouseWheel="FrameSelect_PreviewMouseWheel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" VerticalAlignment="Stretch" BorderThickness="1" BorderBrush="Transparent" Margin="10 10 10 0">
                            <Grid Background="Transparent">
                                <!-- Slider aligned right -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    x:Name="FrameVerticalScrollBar"
                                    Orientation="Vertical"
                                    Grid.Column="1"
                                    Margin="10 0 0 0"
                                    Minimum="0"
                                    SmallChange="1"
                                    LargeChange="1"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="FrameVerticalScrollBar_ValueChanged"
                                    PreviewMouseDown="FrameVerticalScrollBar_PreviewMouseDown"
                                    Template="{StaticResource FrameVerticalSliderTemplate}"
                                >
                                    <Slider.LayoutTransform>
                                        <ScaleTransform ScaleY="-1"/>
                                    </Slider.LayoutTransform>
                                </Slider>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Button
                                    x:Name="RemovePatternButton"
                                    VerticalAlignment="Bottom"
                                    Margin="10 0 5 10"
                                    Padding="5"
                                    FontWeight="DemiBold"
                                    Background="#babae0"
                                    Click="RemovePatternButton_Click"
                                >
                                    Remove Selected Pattern
                                </Button>
                            </Grid>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Button
                                        x:Name="AddPatternButton"
                                        VerticalAlignment="Bottom"
                                        Margin="5 0 10 10"
                                        Padding="5"
                                        FontWeight="DemiBold"
                                        Background="#babae0"
                                        Click="AddPatternButton_Click"
                                    >
                                        Add Pattern
                                    </Button>
                                </Grid>
                                <Grid Grid.Column="1">
                                    <Button
                                        x:Name="DuplicatePatternButton"
                                        VerticalAlignment="Bottom"
                                        Margin="0 0 10 10"
                                        Padding="5"
                                        FontWeight="DemiBold"
                                        Background="#babae0"
                                        Click="DuplicatePatternButton_Click"
                                    >
                                        Duplicate Pattern
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderThickness="1" BorderBrush="FloralWhite" Margin="10 5 5 10">
                <!-- container for song settings (bpm, speed, row count?, highlight cell number etc.) -->
                <Grid Background="#141424" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Column="0" BorderThickness="0 0 0 1" BorderBrush="FloralWhite">
                        <Grid Grid.Row="0" Background="#353554">
                            <TextBlock
                                x:Name="SettingsSection"
                                Text="Settings"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Margin="10 0 0 2"
                                TextAlignment="Left"
                                Grid.Column="0"
                                Foreground="FloralWhite"
                            />
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Focusable="True" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderThickness="1" BorderBrush="Transparent" Margin="10 10 5 10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0 12 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Grid.Column="0"
                                        Text="BPM:"
                                        Foreground="FloralWhite"
                                        FontSize="13"
                                        FontWeight="DemiBold"
                                    />
                                    <TextBox
                                        x:Name="BPMTextBox"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Text="{Binding BPM, UpdateSourceTrigger=LostFocus}"
                                        PreviewTextInput="NumberOnly"
                                        KeyDown="TextBox_KeyDown"
                                        Tag="BPM_Value"
                                        Width="40"
                                        Height="20"
                                        Background="#babae0"
                                        FontWeight="DemiBold"
                                    />
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <RepeatButton
                                            x:Name="BPM_Up_Button"
                                            Tag="BPM_Up" Content="▲"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                        <RepeatButton
                                            x:Name="BPM_Down_Button"
                                            Tag="BPM_Down"
                                            Content="▼"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0 12 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Grid.Column="0"
                                        Text="Speed:"
                                        Foreground="FloralWhite"
                                        FontSize="13"
                                        FontWeight="DemiBold"
                                    />
                                    <TextBox
                                        x:Name="SpeedTextBox"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Text="{Binding Speed, UpdateSourceTrigger=LostFocus}"
                                        PreviewTextInput="NumberOnly"
                                        KeyDown="TextBox_KeyDown"
                                        Tag="Speed_Value"
                                        Width="40"
                                        Height="20"
                                        Background="#babae0"
                                        FontWeight="DemiBold"
                                    />
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <RepeatButton
                                            x:Name="Speed_Up_Button"
                                            Tag="Speed_Up"
                                            Content="▲"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                        <RepeatButton
                                            x:Name="Speed_Down_Button"
                                            Tag="Speed_Down"
                                            Content="▼"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="2" Margin="0 12 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Grid.Column="0"
                                        Text="Rows Per Frame:"
                                        Foreground="FloralWhite"
                                        FontSize="13"
                                        FontWeight="DemiBold"
                                    />
                                    <TextBox
                                        x:Name="RowCountTextBox"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Text="{Binding RowCount, UpdateSourceTrigger=LostFocus}"
                                        PreviewTextInput="NumberOnly"
                                        KeyDown="TextBox_KeyDown"
                                        Tag="RowCount_Value"
                                        Width="40"
                                        Height="20"
                                        Background="#babae0"
                                        FontWeight="DemiBold"
                                    />
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <RepeatButton
                                            x:Name="RowCount_Up_Button"
                                            Tag="RowCount_Up"
                                            Content="▲"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                        <RepeatButton
                                            x:Name="RowCount_Down_Button"
                                            Tag="RowCount_Down"
                                            Content="▼"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="3" Margin="0 12 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Grid.Column="0"
                                        Text="Row Highlight:"
                                        Foreground="FloralWhite"
                                        FontSize="13"
                                        FontWeight="DemiBold"
                                    />
                                    <TextBox
                                        x:Name="RowHighlightTextBox"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Text="{Binding RowHighlight, UpdateSourceTrigger=LostFocus}"
                                        PreviewTextInput="NumberOnly"
                                        KeyDown="TextBox_KeyDown"
                                        Tag="RowHighlight_Value"
                                        Width="40"
                                        Height="20"
                                        Background="#babae0"
                                        FontWeight="DemiBold"
                                    />
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <RepeatButton
                                            x:Name="RowHighlight_Up_Button"
                                            Tag="RowHighlight_Up"
                                            Content="▲"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                        <RepeatButton
                                            x:Name="RowHighlight_Down_Button"
                                            Tag="RowHighlight_Down"
                                            Content="▼"
                                            FontSize="5"
                                            Width="15"
                                            Height="10"
                                            Click="SettingsArrow_Click"
                                            Background="#d1d1ed"
                                        />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderThickness="1 0 0 0" BorderBrush="FloralWhite">
                            <Grid Margin="5 10 0 0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button
                                    x:Name="CreateNew_Button"
                                    Grid.Row="0"
                                    VerticalAlignment="Bottom"
                                    Margin="5 0 10 10"
                                    Padding="5"
                                    FontWeight="DemiBold"
                                    Background="#babae0"
                                    Tag="New"
                                    Click="CreateNewButton_Click"
                                >
                                    Create New Project
                                </Button>
                                
                                <Button
                                    x:Name="Save_Button"
                                    Grid.Row="1"
                                    VerticalAlignment="Bottom"
                                    Margin="5 0 10 10"
                                    Padding="5"
                                    FontWeight="DemiBold"
                                    Background="#babae0"
                                    Tag="Save"
                                    Click="SaveButton_Click"
                                >
                                    Save Project
                                </Button>

                                <Button
                                    x:Name="SaveAs_Button"
                                    Grid.Row="2"
                                    VerticalAlignment="Bottom"
                                    Margin="5 0 10 10"
                                    Padding="5"
                                    FontWeight="DemiBold"
                                    Background="#babae0"
                                    Tag="Save_As"
                                    Click="SaveButton_Click"
                                >
                                    Save Project As...
                                </Button>

                                <Button
                                    x:Name="Load_Button"
                                    Grid.Row="3"
                                    VerticalAlignment="Bottom"
                                    Margin="5 0 10 10"
                                    Padding="5"
                                    FontWeight="DemiBold"
                                    Background="#babae0"
                                    Tag="New"
                                    Click="LoadButton_Click"
                                >
                                    Load Project
                                </Button>

                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- MARGIN: LEFT, TOP, RIGHT, BOTTOM -->
            <Border Grid.Column="3" BorderThickness="1" BorderBrush="FloralWhite" Margin="5 5 10 10">
                <!-- container for preset selection -->
                <Grid Background="Transparent" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Column="0" BorderThickness="0 0 0 1" BorderBrush="FloralWhite">
                        <Grid Grid.Row="0" Background="#353554">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="SoundFontSectionTitle"
                                Grid.Column="0"
                                Text="SoundFont Manager"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Margin="10 0 0 2"
                                TextAlignment="Left"
                                Foreground="FloralWhite"
                            />
                            <TextBlock
                                x:Name="SelectedSoundFont"
                                Grid.Column="2"
                                Text=""
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch"
                                FontWeight="DemiBold"
                                TextAlignment="Right"
                                Foreground="FloralWhite"
                            />
                            <Button
                                x:Name="OpenSF2_Button"
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Margin="10 5 10 5"
                                Padding="5"
                                FontWeight="DemiBold"
                                Background="#babae0"
                                Click="OpenSF2Button_Click"
                            >
                                Import .sf2 File
                            </Button>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ListBox
                            Grid.Column="1"
                            ItemsSource="{Binding Presets}"
                            SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                            PreviewKeyDown="ListBox_PreviewKeyDown"
                            SelectionChanged="ListBox_SelectionChanged"
                            Background="#141424"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            BorderBrush="Transparent"
                            BorderThickness="0 1 0 0"
                        >
                            <ListBox.Resources>
                                <Style x:Key="HorizontalThumbStyle" TargetType="Thumb">
                                    <Setter Property="Height" Value="8"/>
                                    <Setter Property="Background" Value="FloralWhite"/>
                                    <Setter Property="Margin" Value="5 0 5 0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="ScrollBar">
                                    <Style.Triggers>
                                        <Trigger Property="Orientation" Value="Horizontal">
                                            <Setter Property="Height" Value="8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid Background="Transparent">
                                                            <Track x:Name="PART_Track">
                                                                <Track.DecreaseRepeatButton>
                                                                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                                                                </Track.DecreaseRepeatButton>

                                                                <Track.Thumb>
                                                                    <Thumb Style="{StaticResource HorizontalThumbStyle}"/>
                                                                </Track.Thumb>

                                                                <Track.IncreaseRepeatButton>
                                                                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                                                                </Track.IncreaseRepeatButton>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Resources>
                            
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="FloralWhite"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="ScrollViewer.HorizontalAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- container to separate controls from tracker -->
        <Grid Background="Transparent" Grid.Row="1">
            <Border BorderThickness="1" Height="1" BorderBrush="FloralWhite" Grid.Row="1" />
        </Grid>

        <!-- container for tracker grid and vertical slider -->
        <Grid Background="Transparent" MouseLeftButtonDown="Tracker_MouseLeftButtonDown" PreviewMouseWheel="Tracker_PreviewMouseWheel" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <!-- tracker part -->
                <ColumnDefinition Width="Auto" />
                <!-- scroll bar part -->
            </Grid.ColumnDefinitions>

            <!-- TrackerGrid aligned left -->
            <local:TrackerGrid
                x:Name="Tracker"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Margin="40 200 0 200"
            />

            <!-- Slider aligned right -->
            <Slider
                x:Name="VerticalScrollBar"
                Orientation="Vertical"
                Grid.Column="1"
                Margin="0 10 10 10"
                Minimum="0"
                SmallChange="1"
                LargeChange="1"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="VerticalScrollBar_ValueChanged"
                Template="{StaticResource VerticalSliderTemplate}"
                >
                <Slider.LayoutTransform>
                    <ScaleTransform ScaleY="-1"/>
                </Slider.LayoutTransform>
            </Slider>
        </Grid>

        <!-- bottom section for horizontal scrollbar -->
        <Grid Background="#1f1e33" Grid.Row="3" Panel.ZIndex="1">
            <Border Background="Transparent" Margin="0 0 0 0" BorderThickness="0 1 0 0" BorderBrush="FloralWhite" />
            <Slider
                x:Name="HorizontalScrollBar"
                Minimum="0"
                IsSnapToTickEnabled="True"
                IsMoveToPointEnabled="False"
                Height="20"
                ValueChanged="HorizontalScrollBar_ValueChanged"
                Template="{StaticResource HorizontalSliderTemplate}"
            />
        </Grid>
    </Grid>
</Window>